# Notion API
NOTION_API_TOKEN=ntn_your_token
NOTION_ROOT_PAGE=uuid-root-page

# Unsplash API — обложки карточек (бесплатно, 50 req/час)
UNSPLASH_ACCESS_KEY=your_access_key

# Telegram username заказчика (без @)
PERSON_TG_USERNAME=username

# Ключевое слово главного проекта (для объединения карточек в Notion)
MAIN_PROJECT_KEYWORD=keyword
